# ==============================
# Conzet Auto-Traffic Engine ENV
# Fill these, then rename this file to `.env`
# ==============================

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app_password_here
SMTP_FROM=you@example.com

# === Discord ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/XXXX

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_token_here
TELEGRAM_CHAT_IDS=123456789,987654321   # comma-separated

# === Twitter/X (v2 API or v1.1 via OAuth 1.0a) ===
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# === Reddit (PRAW) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=conzet-engine-script/0.1

# === Facebook Page (Graph API) ===
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# === General ===
PAYMENT_URL=https://your-payment-link-here.com
ASSET_QR=assets/ascension_kit_qr.png
ASSET_PDF=assets/ascension_kit_onepager.pdf
RATE_PER_MINUTE=20
