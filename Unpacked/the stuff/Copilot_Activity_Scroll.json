          "sorry",
          "apologize",
          "can't",
          "unable",
          "not supported"
        ],
        "breakthrough": [
          "aha",
          "got it",
          "that works",
          "fixed",
          "solved"
        ]
      },
      "metrics": [
        "Spike Score (0–10) based on profanity+caps+exclaims",
        "Polarity shifts (AI vs Human) over time",
        "Apology-loop density (AI)",
        "Resolution markers (breakthrough phrases)"
      ],
      "invocations": [
        "Shadow, scan Copilot stream for spikes between [START] and [END].",
        "Shadow, list top-10 spikes (timestamp, author, snippet).",
        "Shadow, show apology-loop segments.",
        "Shadow, show breakthrough pivots after conflict."
      ],
      "outputs": [
        "Spike timeline",
        "Hot snippets (timestamped)",
        "Loop segments",
        "Breakthrough list"
      ]
    }
  }
